DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev; switch to PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/ideas_block

# Email (console backend for dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use SMTP:
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=noreply@ideas-block.com
# EMAIL_HOST_PASSWORD=secret

CONTACT_EMAIL=contact@ideas-block.com

# WordPress import
WP_SQL_PATH=../ideas-block.com/iopaveqd_wp290_20260328.sql

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use TEST keys (pk_test_... / sk_test_...) for development
# Use LIVE keys (pk_live_... / sk_live_...) for production only
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook secret — from https://dashboard.stripe.com/webhooks
# Run: stripe listen --forward-to localhost:8000/tickets/webhook/stripe/
# to get the whsec_... value during development
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Subscription Price IDs — create these in Stripe Dashboard > Products
# Create two recurring prices (monthly) and paste their IDs here
# e.g. price_1ABC... and price_1DEF...
STRIPE_PRICE_SUPPORTER=price_REPLACE_ME
STRIPE_PRICE_PATRON=price_REPLACE_ME
