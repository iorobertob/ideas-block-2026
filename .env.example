# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.
#
# For local development, only the Stripe keys are strictly needed
# (and only if you want to test payments). Everything else has safe defaults.

# ── Django ────────────────────────────────────────────────────────────────────
# Use 'production' on the server, 'dev' locally (DEBUG=True, SQLite, console email)
DJANGO_SETTINGS_MODULE=ideas_block.settings.dev

# Set to True temporarily to see full error tracebacks in the browser.
DEBUG=False

# Required in production. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# Comma-separated. In dev, localhost is allowed automatically.
ALLOWED_HOSTS=ideas-block.com,www.ideas-block.com

# Full URL used in Wagtail notification emails
SITE_URL=https://ideas-block.com

# ── Database (PostgreSQL — production only) ───────────────────────────────────
# Dev uses SQLite automatically via dev.py settings.
# Production uses these variables via production.py settings.
DB_NAME=ideas_block
DB_USER=ideas_block_user
DB_PASSWORD=REPLACE_ME
DB_HOST=localhost
DB_PORT=5432

# ── Email (SMTP — production only) ───────────────────────────────────────────
# Dev uses the console backend (emails printed to terminal) — no config needed.
# Production requires a real SMTP provider (e.g. Gmail, Mailgun, Postmark).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=REPLACE_ME
EMAIL_HOST_PASSWORD=REPLACE_ME
DEFAULT_FROM_EMAIL=noreply@ideas-block.com
TICKETS_BCC_EMAIL=contact@ideas-block.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use TEST keys locally (pk_test_ / sk_test_), LIVE keys on the server.
# Keys: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks
#   (for local dev: stripe listen --forward-to localhost:8000/tickets/webhook/stripe/)
# Price IDs: create two monthly recurring products in Stripe Dashboard.
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_SUPPORTER=price_REPLACE_ME
STRIPE_PRICE_PATRON=price_REPLACE_ME

# ── MailerLite ────────────────────────────────────────────────────────────────
# API v2 token from https://dashboard.mailerlite.com/integrations/api
# Leave blank in dev — newsletter signup form will silently skip the API call.
MAILERLITE_API_KEY=

# ── Analytics ─────────────────────────────────────────────────────────────────
# Your domain as registered in https://plausible.io
# Leave blank in dev — the tracking script will not be loaded.
PLAUSIBLE_DOMAIN=ideas-block.com

# ── Ticketing ─────────────────────────────────────────────────────────────────
# Discount in EUR applied to ticket price for active Supporter/Patron members.
MEMBER_DISCOUNT_EUR=2.00
