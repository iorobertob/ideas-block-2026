# ── Python ──────────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Django / Wagtail ────────────────────────────────────────────────
# Database — never commit; transfer with pg_dump / manage.py dumpdata
db.sqlite3
*.sqlite3

# Collected static files (generated by collectstatic — NOT source CSS)
# Source CSS is at ideas_block/static/css/main.css — tracked by git
# Collected output goes to static/ (top-level) — NOT tracked
static/

# ── Media files — NEVER commit; deploy separately ───────────────────
# User-uploaded images and documents can be 1-10 GB.
# Strategy: rsync to server, or use object storage (S3/Spaces/B2).
# See README for deployment instructions.
media/

# ── Secrets ─────────────────────────────────────────────────────────
.env
.env.local
.env.production
local.py
ideas_block/settings/local.py

# ── Logs ────────────────────────────────────────────────────────────
*.log
logs/

# ── OS / Editor ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Docker ──────────────────────────────────────────────────────────
# Keep Dockerfile and docker-compose.yml in git.
# Ignore runtime data volumes:
postgres_data/
redis_data/

# ── Node (if Tailwind build is added later) ──────────────────────────
node_modules/
npm-debug.log
yarn-error.log
